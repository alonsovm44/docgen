
INTENT: "Docgen is a CLI-driven tool that automatically generates and maintains up-to-date, semantic documentation for a codebase. "
AVOID: "Tracking binary files, track only text files"

$$ ABSTRACT DOC_FILE_STRUCT {
    ```Docfile
    Track:
        # this is a comment
        *.cpp % this tracks all .cpp files in CWD and all subdirectories
        dir/subdir/ % this tracks all text files in
    Ignore:
        dir/subdir/secret.cpp
    ```
}$$

$$ ABSTRACT CONFIG_FILE_STRUCT{
    ```docgen_config.json
    {
    "cloud": {
        "api_key": "your api key",
        "api_url": "https://apifreellm.com/api/v1/chat",
        "model_id": "qwen2.5-coder:7b",
        "protocol": "openai"
    },
    "local": {
        "api_url": "http://localhost:11434/api/generate",
        "model_id": "qwen2.5-coder:3b"
        }
    }
    ```
}

$$ init -> DOC_FILE_STRUCT, CONFIG_FILE_STRUCT{
    INTENT: "Check if .docgen/ and Docfile already exists in CWD, if so abort"
    if argv[1] == "init"{
        Make "Docfile" in CWD with structure of DOC_FILE_STRUCT{
            ```
            Track:

            Ignore:
            ```
        }
        Make "docgen_config.json" in ".docgen/" with structure of CONFIG_FILE_STRUCT
        Mkdir ".docgen/" in CWD
        PRINT "Documentation repository initiated in " + CWD 
    }
}$$

$$ config {
    if argv[1] == "config"{
        if argc < 3 {
            print "Usage: docgen config <key> <value>"
            print "Keys: "
        }
    }
}$$

$ get_api_key {if argv[1] == "get-key" then open web browser on <url> } $

$$ track -> DOC_FILE_STRUCT {
    if argv[1] == "track"{
        if argc < 3 {
            print "usage: docgen track <path>"
        }
        path = argv[2]
        Append path or filename to "Docfile" in a new line in the track section
    }
}$$

$$ ignore -> DOC_FILE_STRUCT{
 if argv[1] == "ignore"{
        if argc < 3 {
            print "usage: docgen ignore <path>"
        }
        path = argv[2]
        Append path or filename to "Docfile" in a new line in the ignore section
    }
}$$

$ CHECK_DOCFILE {Check if "Docfile" exists in CWD, if not return false }$

