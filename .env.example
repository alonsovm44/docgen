# =========================================
# Gendox Configuration - .env.example
# Copy this to `.env` and fill in your keys/settings
# =========================================

# -------------------------------
# General settings
# -------------------------------
# Choose backend mode: 'local' (default) or 'cloud'
GENDOX_MODE=local

# Project path (optional, defaults to current directory)
GENDOX_PROJECT_PATH=.

# Logging verbosity: 'debug', 'info', 'warn', 'error'
GENDOX_LOG_LEVEL=info

# -------------------------------
# Local AI (Ollama) settings
# -------------------------------
# Only needed if using local AI
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# -------------------------------
# OpenAI API settings
# -------------------------------
# Only needed if GENDOX_MODE=cloud and protocol=openai
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o
OPENAI_API_BASE=https://api.openai.com/v1

# Optional: OpenAI timeout in seconds
OPENAI_TIMEOUT=60

# -------------------------------
# Azure OpenAI settings
# -------------------------------
# Only needed if using Azure OpenAI
AZURE_OPENAI_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_MODEL=gpt-4o

# -------------------------------
# Google Vertex AI / Gemini settings
# -------------------------------
# Only needed if using Google Cloud AI
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_MODEL=gemini-1.5-codechat

# -------------------------------
# Optional advanced settings
# -------------------------------
# Max tokens per request (for cloud models)
GENDOX_MAX_TOKENS=2000

# Temperature / creativity for AI responses
GENDOX_TEMPERATURE=0.2

# Directory for cached docs
GENDOX_CACHE_DIR=.gendox/cache

# Hashing algorithm for incremental updates (md5/sha1/sha256)
GENDOX_HASH_ALGO=sha256

# Enable/disable telemetry (true/false)
GENDOX_TELEMETRY=false